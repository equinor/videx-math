{
  "name": "@equinor/videx-math",
  "version": "1.1.8",
  "description": "A library with math used by Videx.",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "browser": "dist/index.umd.js",
  "files": [
    "dist"
  ],
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "rollup -c",
    "prepub": "npm run build",
    "pub": "npm publish --access=public",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --color",
    "predocs": "rimraf docs",
    "docs": "typedoc --out docs src",
    "postdocs": "node postdocs.copyfiles.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/equinor/videx-math.git"
  },
  "keywords": [
    "math"
  ],
  "author": "Tom Kristian Tjemsland",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/equinor/videx-math/issues"
  },
  "homepage": "https://github.com/equinor/videx-math#readme",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/jest": "^30.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.60.0",
    "tslib": "^2.8.1",
    "typedoc": "^0.28.18",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.10"
  }
}
