{
  "compilerOptions": {
    "declaration": true,
    "declarationDir": "./dist",
    "rootDirs": ["./src", "./test"],
    "types": ["node", "vitest/globals"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noImplicitAny": true,
    "outDir": "./dist",
    "target": "ES6"
  },
  "include": ["src/*", "postdocs.copyfiles.mjs", "test/*"],
  "exclude": ["node_modules"]
}
